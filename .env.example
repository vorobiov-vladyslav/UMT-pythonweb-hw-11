# Database (host-side; Docker compose injects its own @postgres:5432 URL)
DATABASE_URL=postgresql+psycopg://postgres:hw11secret@localhost:5433/hw11

# JWT — REQUIRED. Generate one, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=604800

# Mail (smtp.meta.ua)
MAIL_USERNAME=example@meta.ua
MAIL_PASSWORD=secretPassword
MAIL_FROM=example@meta.ua
MAIL_PORT=465
MAIL_SERVER=smtp.meta.ua
MAIL_FROM_NAME=Contacts API
MAIL_STARTTLS=False
MAIL_SSL_TLS=True
USE_CREDENTIALS=True
VALIDATE_CERTS=True

# Cloudinary (Dashboard -> Product Environment Credentials)
CLOUDINARY_NAME=cloud_name
CLOUDINARY_API_KEY=api_key
CLOUDINARY_API_SECRET=api_secret

# CORS — JSON list, or ["*"] for any origin
CORS_ORIGINS=["*"]
